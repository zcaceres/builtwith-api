{
  "name": "builtwith-api",
  "version": "3.0.0",
  "description": "Wrapper for the BuiltWith API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun run build:js && bun run build:types",
    "build:js": "bun build ./src/index.ts --outdir dist --target node --format esm --sourcemap=external --external zod",
    "build:types": "tsc --emitDeclarationOnly",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "smoke": "bun test.ts",
    "clean": "rm -rf dist"
  },
  "homepage": "https://github.com/zcaceres/builtwith-api",
  "repository": {
    "type": "git",
    "url": "https://github.com/zcaceres/builtwith-api.git"
  },
  "keywords": [
    "utilities",
    "BuiltWith",
    "apis",
    "technology-detection",
    "web-intelligence"
  ],
  "files": [
    "dist"
  ],
  "author": "Zach Caceres (@zachcaceres)",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "typescript": "^5"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
