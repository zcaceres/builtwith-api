{
  "name": "builtwith-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "lint": "biome check packages/",
    "lint:fix": "biome check --write packages/",
    "test": "bun run --filter '*' test",
    "clean": "rm -rf packages/*/dist",
    "docs:api": "typedoc",
    "docs:dev": "bun run docs:api && vitepress dev docs",
    "docs:build": "bun run docs:api && vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/bun": "^1.3.9",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^5",
    "vitepress": "^1.6.4"
  }
}
